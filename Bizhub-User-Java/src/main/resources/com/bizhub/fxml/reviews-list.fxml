<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.bizhub.controller.users_avis.review.ReviewManagementController"
            fx:id="root"
            stylesheets="@../css/theme.css">

    <left>
        <!-- Controller will swap this include to admin-sidebar.fxml when needed -->
        <fx:include fx:id="sidebarInclude" source="user-sidebar.fxml" />
    </left>

    <top>
        <HBox spacing="12" alignment="CENTER_LEFT" styleClass="topbar">
            <padding>
                <Insets top="14" right="16" bottom="14" left="16" />
            </padding>

            <VBox spacing="2">
                <Text text="Reviews" styleClass="h1" />
                <Text text="Cards view" styleClass="subtitle" />
            </VBox>

            <Pane HBox.hgrow="ALWAYS" />
        </HBox>
    </top>

    <center>
        <VBox spacing="12">
            <padding>
                <Insets top="14" right="16" bottom="16" left="16" />
            </padding>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="Search (user, formation, comment...)" styleClass="text-field-modern" HBox.hgrow="ALWAYS" />

                <ComboBox fx:id="formationFilter" prefWidth="220" />

                <ComboBox fx:id="ratingFilter" prefWidth="140" />

                <Button text="Refresh" onAction="#refresh" styleClass="btn" />
                <Button text="Export CSV" onAction="#exportCsv" styleClass="btn-primary" />
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="View" onAction="#viewSelected" styleClass="btn" />
                <Button fx:id="deleteButton" text="Delete" onAction="#deleteSelected" styleClass="danger-button" />
                <Pane HBox.hgrow="ALWAYS" />
                <Label fx:id="statsLabel" text="" styleClass="hint" />
            </HBox>

            <ListView fx:id="reviewsList" VBox.vgrow="ALWAYS" styleClass="cards-list" />
        </VBox>
    </center>

</BorderPane>
