<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<BorderPane
        stylesheets="@../css/theme.css,@../css/user-management.css"
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.bizhub.controller.marketplace.ProduitServiceController">

    <!-- LEFT : Sidebar -->
    <left>
        <fx:include source="admin-sidebar.fxml"/>
    </left>

    <!-- TOP : Topbar -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="topbar">
            <padding>
                <Insets top="14" right="16" bottom="14" left="16"/>
            </padding>
            <Text styleClass="h1" text="Produits/Services"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Label styleClass="subtitle form-label" text="Recherche"/>
            <TextField fx:id="tfSearchNom" promptText="Nom..." prefWidth="220"/>
            <Label styleClass="subtitle form-label" text="Catégorie"/>
            <ComboBox fx:id="cbFilterCategorie" prefWidth="160"/>
        </HBox>
    </top>

    <!-- CENTER -->
    <center>
        <VBox spacing="14">
            <padding>
                <Insets top="14" right="16" bottom="16" left="16"/>
            </padding>

            <!-- KPI -->
            <HBox spacing="12">
                <VBox spacing="6" styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <Text styleClass="stat-title" text="Total Produits"/>
                    <Text fx:id="kpiTotalProduits" styleClass="stat-value" text="0"/>
                </VBox>
                <VBox spacing="6" styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <Text styleClass="stat-title" text="Disponibles"/>
                    <Text fx:id="kpiDisponibles" styleClass="stat-value" text="0"/>
                </VBox>
                <VBox spacing="6" styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <Text styleClass="stat-title" text="Catégories"/>
                    <Text fx:id="kpiCategories" styleClass="stat-value" text="0"/>
                </VBox>
            </HBox>

            <!-- Form + Tables -->
            <HBox spacing="12" VBox.vgrow="ALWAYS">

                <!-- ══════════════════════════════
                     COLONNE GAUCHE : Form CRUD
                ══════════════════════════════ -->
                <VBox spacing="10" styleClass="card" prefWidth="360">
                    <Text styleClass="h2" text="Gestion Produit/Service"/>

                    <GridPane hgap="10" vgap="6">
                        <columnConstraints>
                            <ColumnConstraints prefWidth="110"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>

                        <!-- Id Profile -->
                        <Label text="Id Profile" styleClass="form-label"
                               GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="tfIdProfile" promptText="ex: 1"
                                   GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                        <HBox fx:id="hboxValIdProfile" spacing="5" alignment="CENTER_LEFT"
                              visible="false" managed="false"
                              GridPane.rowIndex="1" GridPane.columnIndex="1">
                            <Label fx:id="iconValIdProfile" text=""/>
                            <Label fx:id="lblValIdProfile"  text="" wrapText="true"/>
                        </HBox>

                        <!-- Nom -->
                        <Label text="Nom" styleClass="form-label"
                               GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <TextField fx:id="tfNom" promptText="Nom..."
                                   GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                        <HBox fx:id="hboxValNom" spacing="5" alignment="CENTER_LEFT"
                              visible="false" managed="false"
                              GridPane.rowIndex="3" GridPane.columnIndex="1">
                            <Label fx:id="iconValNom" text=""/>
                            <Label fx:id="lblValNom"  text="" wrapText="true"/>
                        </HBox>

                        <!-- Prix -->
                        <Label text="Prix (TND)" styleClass="form-label"
                               GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                        <TextField fx:id="tfPrix" promptText="ex: 49.90"
                                   GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                        <HBox fx:id="hboxValPrix" spacing="5" alignment="CENTER_LEFT"
                              visible="false" managed="false"
                              GridPane.rowIndex="5" GridPane.columnIndex="1">
                            <Label fx:id="iconValPrix" text=""/>
                            <Label fx:id="lblValPrix"  text="" wrapText="true"/>
                        </HBox>

                        <!-- Quantité -->
                        <Label text="Quantité" styleClass="form-label"
                               GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                        <TextField fx:id="tfQuantite" promptText="ex: 10"
                                   GridPane.rowIndex="6" GridPane.columnIndex="1"/>
                        <HBox fx:id="hboxValQuantite" spacing="5" alignment="CENTER_LEFT"
                              visible="false" managed="false"
                              GridPane.rowIndex="7" GridPane.columnIndex="1">
                            <Label fx:id="iconValQuantite" text=""/>
                            <Label fx:id="lblValQuantite"  text="" wrapText="true"/>
                        </HBox>

                        <!-- Catégorie -->
                        <Label text="Catégorie" styleClass="form-label"
                               GridPane.rowIndex="8" GridPane.columnIndex="0"/>
                        <TextField fx:id="tfCategorie" promptText="ex: Design"
                                   GridPane.rowIndex="8" GridPane.columnIndex="1"/>
                        <HBox fx:id="hboxValCategorie" spacing="5" alignment="CENTER_LEFT"
                              visible="false" managed="false"
                              GridPane.rowIndex="9" GridPane.columnIndex="1">
                            <Label fx:id="iconValCategorie" text=""/>
                            <Label fx:id="lblValCategorie"  text="" wrapText="true"/>
                        </HBox>

                        <!-- Disponible -->
                        <Label text="Disponible" styleClass="form-label"
                               GridPane.rowIndex="10" GridPane.columnIndex="0"/>
                        <CheckBox fx:id="cbDisponible" text="Oui" selected="true"
                                  GridPane.rowIndex="10" GridPane.columnIndex="1"/>

                        <!-- Description -->
                        <Label text="Description" styleClass="form-label"
                               GridPane.rowIndex="11" GridPane.columnIndex="0"/>
                        <TextArea fx:id="taDescription" promptText="Description..."
                                  prefRowCount="3"
                                  GridPane.rowIndex="11" GridPane.columnIndex="1"/>
                    </GridPane>

                    <!-- Message global CRUD -->
                    <HBox fx:id="hboxMsgCrud" spacing="6" alignment="CENTER_LEFT"
                          visible="false" managed="false">
                        <Label fx:id="iconMsgCrud" text=""/>
                        <Label fx:id="lblMsgCrud"  text="" wrapText="true"/>
                    </HBox>

                    <Separator/>

                    <HBox spacing="10">
                        <Button fx:id="btnAjouter"   text="Ajouter"   onAction="#onAjouter"
                                maxWidth="1e9" styleClass="btn-primary"   HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnModifier"  text="Modifier"  onAction="#onModifier"
                                maxWidth="1e9" styleClass="btn-secondary" HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <HBox spacing="10">
                        <Button fx:id="btnSupprimer" text="Supprimer" onAction="#onSupprimer"
                                maxWidth="1e9" styleClass="btn-danger"    HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnVider"     text="Vider"     onAction="#onVider"
                                maxWidth="1e9" styleClass="btn-secondary" HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>

                <!-- ══════════════════════════════
                     COLONNE DROITE : Tables
                ══════════════════════════════ -->
                <VBox spacing="12" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">

                    <!-- Table Produits -->
                    <VBox spacing="8" styleClass="card" VBox.vgrow="ALWAYS">
                        <Text styleClass="h2" text="Liste Produits/Services"/>
                        <TableView fx:id="tableProduits" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colNom"        text="Nom"       prefWidth="180"/>
                                <TableColumn fx:id="colCategorie"  text="Catégorie" prefWidth="140"/>
                                <TableColumn fx:id="colQuantite"   text="Qté"       prefWidth="70"/>
                                <TableColumn fx:id="colPrix"       text="Prix"      prefWidth="100"/>
                                <TableColumn fx:id="colDisponible" text="Dispo"     prefWidth="70"/>
                            </columns>
                            <placeholder>
                                <Label text="Aucun produit." styleClass="muted"/>
                            </placeholder>
                        </TableView>
                    </VBox>

                    <!-- ══════════════════════════════
                         SECTION COMMANDES INVESTISSEUR
                    ══════════════════════════════ -->
                    <VBox fx:id="boxCommandesInvestor" spacing="10" styleClass="card"
                          visible="false" managed="false" VBox.vgrow="ALWAYS">

                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Text styleClass="h2" text="Commandes reçues"/>
                            <Pane HBox.hgrow="ALWAYS"/>
                            <Button text="↺ Rafraîchir" onAction="#refreshCommandes"
                                    styleClass="btn-secondary"/>
                        </HBox>

                        <!-- Info commande sélectionnée -->
                        <HBox fx:id="hboxCmdInfo" spacing="8" alignment="CENTER_LEFT"
                              visible="false" managed="false">
                            <Label text="▶" style="-fx-text-fill:#E8A93A;-fx-font-weight:bold;"/>
                            <Label fx:id="lblCmdInfo" text="" styleClass="hint" wrapText="true"/>
                        </HBox>

                        <!-- ✅ Table commandes avec colonnes paiement -->
                        <TableView fx:id="tableCommandes" VBox.vgrow="ALWAYS" prefHeight="260">
                            <columns>
                                <!-- Colonnes masquées en runtime -->
                                <TableColumn fx:id="colCmdId"     text="ID"      prefWidth="55"/>
                                <TableColumn fx:id="colCmdClient" text="Client"  prefWidth="70"/>

                                <!-- Colonnes visibles -->
                                <TableColumn fx:id="colCmdProduit"  text="Produit"   prefWidth="160"/>
                                <TableColumn fx:id="colCmdQte"      text="Qté"       prefWidth="50"/>
                                <TableColumn fx:id="colCmdStatut"   text="Statut"    prefWidth="115"/>
                                <TableColumn fx:id="colCmdPriorite" text="Priorité"  prefWidth="115"/>
                                <TableColumn fx:id="colCmdScore"    text="Score"     prefWidth="100"/>

                                <!-- ✅ Colonne paiement Stripe -->
                                <TableColumn fx:id="colCmdPaymentStatus"
                                             text="Paiement"
                                             prefWidth="115"/>

                                <!-- ✅ Colonne payée oui/non -->
                                <TableColumn fx:id="colCmdPayee"
                                             text="Payée ?"
                                             prefWidth="100"/>

                                <!-- ✅ Colonne date paiement -->
                                <TableColumn fx:id="colCmdPaidAt"
                                             text="Date paiement"
                                             prefWidth="140"/>
                            </columns>
                            <placeholder>
                                <Label text="Aucune commande reçue." styleClass="muted"/>
                            </placeholder>
                        </TableView>

                        <!-- Actions investisseur -->
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Button fx:id="btnConfirmerCmd"
                                    text="✔  Confirmer"
                                    onAction="#onConfirmerCommande"
                                    styleClass="btn-primary"/>
                            <Button fx:id="btnAnnulerCmd"
                                    text="✖  Annuler"
                                    onAction="#onAnnulerCommande"
                                    styleClass="btn-danger"/>
                        </HBox>

                        <!-- Message inline commandes -->
                        <HBox fx:id="hboxMsgCmd" spacing="6" alignment="CENTER_LEFT"
                              visible="false" managed="false">
                            <Label fx:id="iconMsgCmd" text=""/>
                            <Label fx:id="lblMsgCmd"  text="" wrapText="true"/>
                        </HBox>

                        <Label text="💡 Seules les commandes « en attente » peuvent être confirmées ou annulées."
                               styleClass="muted" wrapText="true"/>
                    </VBox>

                </VBox>
            </HBox>
        </VBox>
    </center>

</BorderPane>
