<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<BorderPane
        stylesheets="@../css/theme.css,@../css/user-management.css"
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.bizhub.controller.marketplace.CommandeController">

    <left>
        <fx:include source="user-sidebar.fxml"/>
    </left>

    <!-- ═════════════════════ TOPBAR (même look que Tracking) ═════════════════════ -->
    <top>
        <VBox spacing="12" styleClass="topbar">
            <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="12">

                <!-- Panier (startup) -->
                <StackPane fx:id="stackPanier" visible="false" managed="false">
                    <Button fx:id="btnOuvrirPanier"
                            text="🛒 Mon Panier"
                            onAction="#onOuvrirPanier"
                            styleClass="btn-primary"/>

                    <Label fx:id="lblBadgePanier"
                           text="0"
                           visible="false" managed="false"
                           styleClass="badge-danger"
                           StackPane.alignment="TOP_RIGHT"/>
                </StackPane>

                <!-- Tracking -->
                <Button fx:id="btnTracking"
                        text="📦 Suivi de commandes"
                        onAction="#onTrackerCommandes"
                        visible="false" managed="false"
                        styleClass="btn-secondary"/>

                <Text text="Commandes" styleClass="h1"/>
                <Pane HBox.hgrow="ALWAYS"/>

                <Label text="Statut" styleClass="form-label"/>
                <ComboBox fx:id="cbFilterStatut" prefWidth="160"/>

                <Label fx:id="lblFilterClient" text="Client ID" styleClass="form-label"
                       visible="false" managed="false"/>
                <TextField fx:id="tfFilterClient" promptText="ex: 42" prefWidth="120"
                           visible="false" managed="false"/>

                <Button text="↺ Rafraîchir" onAction="#refreshJoin" styleClass="btn-secondary"/>
            </HBox>

            <!-- KPIs -->
            <HBox spacing="12">
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="4" alignment="CENTER_LEFT">
                    <Text styleClass="stat-title" text="Total"/>
                    <Text fx:id="kpiTotal" styleClass="stat-value" text="0"/>
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="4" alignment="CENTER_LEFT">
                    <Text styleClass="stat-title" text="En attente"/>
                    <Text fx:id="kpiAttente" styleClass="stat-value" text="0"/>
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="4" alignment="CENTER_LEFT">
                    <Text styleClass="stat-title" text="Confirmées"/>
                    <Text fx:id="kpiConfirmee" styleClass="stat-value" text="0"/>
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="4" alignment="CENTER_LEFT">
                    <Text styleClass="stat-title" text="Payées"/>
                    <Text fx:id="kpiPayee" styleClass="stat-value" text="0"/>
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="4" alignment="CENTER_LEFT">
                    <Text styleClass="stat-title" text="Livrées"/>
                    <Text fx:id="kpiLivree" styleClass="stat-value" text="0"/>
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="4" alignment="CENTER_LEFT">
                    <Text styleClass="stat-title" text="Annulées"/>
                    <Text fx:id="kpiAnnulee" styleClass="stat-value" text="0"/>
                </VBox>
            </HBox>

        </VBox>
    </top>

    <!-- ═════════════════════ CONTENT ═════════════════════ -->
    <center>
        <HBox spacing="16">
            <padding><Insets top="14" right="16" bottom="16" left="16"/></padding>

            <!-- LEFT CARD -->
            <VBox fx:id="cardForm" spacing="14" styleClass="card" prefWidth="380" minWidth="340">
                <Text fx:id="titleForm" text="Passer une commande" styleClass="h2"/>

                <!-- STARTUP -->
                <VBox fx:id="boxAdd" spacing="10">

                    <Label text="Produit / Service" styleClass="form-label"/>
                    <ComboBox fx:id="cbProduit" promptText="Choisir un produit..." maxWidth="1e9"/>

                    <HBox fx:id="hboxValProduit" spacing="6" alignment="CENTER_LEFT"
                          visible="false" managed="false" styleClass="inline-msg">
                        <Label fx:id="iconValProduit" text=""/>
                        <Label fx:id="lblValProduit" text="" wrapText="true"/>
                    </HBox>

                    <Label text="Quantité" styleClass="form-label"/>
                    <TextField fx:id="tfQuantite" promptText="Nombre entier > 0"/>

                    <HBox fx:id="hboxValQte" spacing="6" alignment="CENTER_LEFT"
                          visible="false" managed="false" styleClass="inline-msg">
                        <Label fx:id="iconValQte" text=""/>
                        <Label fx:id="lblValQte" text="" wrapText="true"/>
                    </HBox>

                    <!-- Boutons -->
                    <HBox spacing="8">
                        <Button fx:id="btnAjouter"
                                text="⚡ Commander direct"
                                onAction="#onAjouter"
                                HBox.hgrow="ALWAYS" maxWidth="1e9"
                                styleClass="btn-primary"/>
                        <Button fx:id="btnAjouterPanier"
                                text="🛒 + Panier"
                                onAction="#onAjouterAuPanier"
                                HBox.hgrow="ALWAYS" maxWidth="1e9"
                                styleClass="btn-warning"/>
                    </HBox>

                    <Label text="⚡ Direct = 1 commande immédiate  |  🛒 Panier = regrouper plusieurs produits"
                           styleClass="muted" wrapText="true"/>

                    <HBox fx:id="hboxMsgAdd" spacing="6" alignment="CENTER_LEFT"
                          visible="false" managed="false" styleClass="inline-msg">
                        <Label fx:id="iconMsgAdd" text=""/>
                        <Label fx:id="lblMsgAdd" text="" wrapText="true"/>
                    </HBox>

                    <Separator opacity="0.35"/>

                    <!-- PAIEMENT -->
                    <VBox fx:id="boxPaiement" spacing="10"
                          visible="false" managed="false"
                          styleClass="payment-card">

                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="✔" styleClass="payment-icon"/>
                            <Label fx:id="lblInfoPaiement" text=""
                                   styleClass="payment-text"
                                   wrapText="true"/>
                        </HBox>

                        <Button fx:id="btnPayer"
                                text="💳  Payer cette commande"
                                onAction="#onPayerCommande"
                                maxWidth="1e9"
                                styleClass="btn-success"/>

                        <ProgressBar fx:id="progressPaiement" maxWidth="1e9" progress="0"
                                     visible="false" managed="false"
                                     styleClass="progress-success"/>

                        <HBox fx:id="hboxMsgPaiement" spacing="6" alignment="CENTER_LEFT"
                              visible="false" managed="false" styleClass="inline-msg">
                            <Label fx:id="iconMsgPaiement" text=""/>
                            <Label fx:id="lblMsgPaiement" text="" wrapText="true"/>
                        </HBox>

                        <Button fx:id="btnFacture"
                                text="📄  Télécharger la facture"
                                onAction="#onTelechargerFacture"
                                maxWidth="1e9"
                                visible="false" managed="false"
                                styleClass="btn-secondary"/>
                    </VBox>

                    <!-- SUPPRESSION -->
                    <Label text="Supprimer une commande" styleClass="form-label"/>
                    <Label text="Sélectionnez une ligne en attente puis cliquez :" styleClass="muted" wrapText="true"/>

                    <Button fx:id="btnSupprimer"
                            text="🗑  Supprimer"
                            onAction="#onSupprimer"
                            maxWidth="1e9"
                            styleClass="btn-danger"/>

                    <HBox fx:id="hboxMsgDel" spacing="6" alignment="CENTER_LEFT"
                          visible="false" managed="false" styleClass="inline-msg">
                        <Label fx:id="iconMsgDel" text=""/>
                        <Label fx:id="lblMsgDel" text="" wrapText="true"/>
                    </HBox>

                    <Label text="💡 Seules les commandes « en attente » peuvent être supprimées."
                           styleClass="muted" wrapText="true"/>
                </VBox>

                <!-- INVESTISSEUR -->
                <VBox fx:id="boxManage" spacing="10" visible="false" managed="false">
                    <Label text="Commande sélectionnée" styleClass="form-label"/>
                    <Label text="Cliquez sur une ligne dans le tableau pour la sélectionner."
                           styleClass="muted" wrapText="true"/>

                    <HBox fx:id="hboxSelectedInfo" spacing="8" alignment="CENTER_LEFT"
                          visible="false" managed="false" styleClass="inline-msg">
                        <Label text="▶" styleClass="hint"/>
                        <Label fx:id="lblSelectedInfo" text="" styleClass="hint" wrapText="true"/>
                    </HBox>

                    <Separator opacity="0.35"/>

                    <Button fx:id="btnConfirmer"
                            text="✔  Confirmer"
                            onAction="#onConfirmer"
                            maxWidth="1e9"
                            styleClass="btn-primary"/>

                    <Button fx:id="btnAnnuler"
                            text="✖  Annuler"
                            onAction="#onAnnuler"
                            maxWidth="1e9"
                            styleClass="btn-danger"/>

                    <HBox fx:id="hboxMsgStatut" spacing="6" alignment="CENTER_LEFT"
                          visible="false" managed="false" styleClass="inline-msg">
                        <Label fx:id="iconMsgStatut" text=""/>
                        <Label fx:id="lblMsgStatut" text="" wrapText="true"/>
                    </HBox>

                    <Label text="💡 Seules les commandes en attente peuvent être confirmées ou annulées."
                           styleClass="muted" wrapText="true"/>
                </VBox>
            </VBox>

            <!-- RIGHT CARD -->
            <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                <Text text="Liste des commandes" styleClass="h2"/>

                <TableView fx:id="tableCommandes" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colIdCommande"    text="ID"       prefWidth="60"/>
                        <TableColumn fx:id="colIdClient"      text="Client"   prefWidth="80"/>
                        <TableColumn fx:id="colProduitNom"    text="Produit"  prefWidth="260"/>
                        <TableColumn fx:id="colQte"           text="Qté"      prefWidth="60"/>
                        <TableColumn fx:id="colStatut"        text="Statut"   prefWidth="130"/>
                        <TableColumn fx:id="colPaymentStatus" text="Paiement" prefWidth="110"/>
                        <TableColumn fx:id="colPayee"         text="Payée"    prefWidth="80"/>
                    </columns>
                    <placeholder>
                        <Label text="Aucune commande trouvée." styleClass="muted"/>
                    </placeholder>
                </TableView>
            </VBox>

        </HBox>
    </center>

</BorderPane>