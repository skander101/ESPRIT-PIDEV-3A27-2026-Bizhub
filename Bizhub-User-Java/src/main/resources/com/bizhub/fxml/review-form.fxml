<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.bizhub.controller.users_avis.review.ReviewFormController"
      spacing="12" stylesheets="@../css/theme.css" styleClass="card">

    <padding>
        <Insets top="16" right="16" bottom="16" left="16" />
    </padding>

    <Text fx:id="titleText" text="Leave a review" styleClass="h1" />

    <GridPane hgap="12" vgap="10">
        <columnConstraints>
            <ColumnConstraints percentWidth="28" />
            <ColumnConstraints percentWidth="72" />
        </columnConstraints>

        <Label text="Rating" GridPane.rowIndex="0" GridPane.columnIndex="0" />
        <ComboBox fx:id="ratingBox" GridPane.rowIndex="0" GridPane.columnIndex="1" />

        <Label text="Comment" GridPane.rowIndex="1" GridPane.columnIndex="0" />
        <TextArea fx:id="commentArea" prefRowCount="5" wrapText="true" GridPane.rowIndex="1" GridPane.columnIndex="1" />
    </GridPane>

    <Label fx:id="errorLabel" text="" styleClass="error-text" wrapText="true" />

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#cancel" styleClass="btn" />
        <Button fx:id="saveButton" text="Submit" onAction="#save" styleClass="btn-primary" />
    </HBox>

</VBox>
