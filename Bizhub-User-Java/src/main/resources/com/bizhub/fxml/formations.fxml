<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.bizhub.controller.users_avis.formation.FormationManagementController"
            fx:id="root"
            stylesheets="@../css/theme.css">

    <left>
        <!-- Admin must not use the non-admin sidebar; controller will swap to the right one at runtime. -->
        <fx:include fx:id="sidebarInclude" source="user-sidebar.fxml" />
    </left>

    <top>
        <HBox spacing="12" alignment="CENTER_LEFT" styleClass="topbar">
            <padding>
                <Insets top="14" right="16" bottom="14" left="16" />
            </padding>

            <ImageView fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="true">
                <image>
                    <Image url="@../images/site-images/logo.png" />
                </image>
            </ImageView>

            <VBox spacing="2">
                <Text text="Formations" styleClass="h1" />
                <Text text="Browse &amp; manage" styleClass="subtitle" />
            </VBox>
            <Pane HBox.hgrow="ALWAYS" />
        </HBox>
    </top>

    <center>
        <VBox spacing="12">
            <padding>
                <Insets top="14" right="16" bottom="16" left="16" />
            </padding>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="Search by title..." styleClass="text-field-modern" HBox.hgrow="ALWAYS" />
                <Button text="Refresh" onAction="#refresh" styleClass="btn" />
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button fx:id="addButton" text="Add" onAction="#addFormation" styleClass="btn-primary" />
                <Button fx:id="editButton" text="Edit" onAction="#editSelected" styleClass="btn" />
                <Button fx:id="deleteButton" text="Delete" onAction="#deleteSelected" styleClass="danger-button" />
            </HBox>

            <!-- Replace table with cards list -->
            <ListView fx:id="formationsList" VBox.vgrow="ALWAYS" styleClass="cards-list" />

            <Label fx:id="footerLabel" text="" styleClass="hint" />
        </VBox>
    </center>

</BorderPane>
