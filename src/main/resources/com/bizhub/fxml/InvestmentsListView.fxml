<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.bizhub.Investistment.Controllers.InvestmentsListController"
            stylesheets="@../css/theme.css">

    <!-- SIDEBAR -->
    <left>
        <fx:include source="admin-sidebar.fxml" />
    </left>

    <!-- TOP BAR -->
    <top>
        <HBox spacing="12" alignment="CENTER_LEFT" styleClass="topbar">
            <padding>
                <Insets top="14" right="16" bottom="14" left="16" />
            </padding>

            <ImageView fitHeight="40" fitWidth="40" preserveRatio="true">
                <image>
                    <Image url="@../images/site-images/logo.png" />
                </image>
            </ImageView>

            <VBox spacing="2">
                <Text text="Investissements" styleClass="h1" />
                <Text text="Liste des investissements" styleClass="subtitle" />
            </VBox>

            <Pane HBox.hgrow="ALWAYS" />

            <Button text="Retour"  styleClass="btn" />
        </HBox>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <VBox spacing="16">
            <padding>
                <Insets top="14" right="16" bottom="16" left="16" />
            </padding>

            <!-- HEADER CARD -->
            <HBox spacing="20" alignment="CENTER_LEFT" styleClass="card">
                <VBox spacing="5">
                    <Text text="Gestion des Investissements" styleClass="h2"/>
                    <Label fx:id="summaryLabel" text="Chargement..." styleClass="subtitle"/>
                </VBox>

                <Pane HBox.hgrow="ALWAYS"/>

                <Button text="➕ Nouvel Investissement"
                        onAction="#handleNewInvestment"
                        styleClass="btn-primary"/>

                <Button text="🔄 Actualiser"
                        onAction="#handleRefresh"
                        styleClass="btn"/>
            </HBox>

            <!-- FILTER BAR -->
            <HBox spacing="15" alignment="CENTER_LEFT" styleClass="card">
                <TextField fx:id="searchField"
                           promptText="🔍 Rechercher par projet, investisseur..."
                           prefWidth="400"
                           styleClass="text-field-modern"/>

                <ComboBox fx:id="filterComboBox"
                          promptText="Filtrer par statut de paiement"
                          prefWidth="250"
                          styleClass="text-field-modern"/>

                <Button text="Réinitialiser"
                        onAction="#handleResetFilters"
                        styleClass="btn"/>
            </HBox>

            <!-- LIST SCROLL -->
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                <content>
                    <VBox fx:id="investmentsContainer" spacing="20" style="-fx-background-color: transparent;">
                        <padding>
                            <Insets top="5" right="5" bottom="5" left="5"/>
                        </padding>

                        <Label fx:id="emptyLabel"
                               text="Aucun investissement trouvé"
                               visible="false"
                               styleClass="subtitle"
                               style="-fx-padding: 40; -fx-text-fill: #7f8c8d;"/>
                    </VBox>
                </content>
            </ScrollPane>

        </VBox>
    </center>

</BorderPane>
