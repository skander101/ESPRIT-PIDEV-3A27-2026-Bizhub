<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.bizhub.controller.users_avis.user.VerificationController"
           stylesheets="@../css/theme.css">

    <Pane styleClass="bg-gradient" />

    <VBox alignment="CENTER" spacing="20" maxWidth="500" styleClass="card">
        <padding>
            <Insets top="40" right="40" bottom="40" left="40" />
        </padding>

        <!-- Logo and Brand Header -->
        <HBox alignment="CENTER" spacing="14">
            <ImageView fitWidth="48" fitHeight="48" preserveRatio="true" styleClass="logo-image">
                <image>
                    <Image url="@../images/site-images/logo.png" />
                </image>
            </ImageView>
            <VBox spacing="2">
                <Text text="BizHub" styleClass="brand-title" />
                <Text text="Verify Your Account" styleClass="brand-subtitle" />
            </VBox>
        </HBox>

        <Separator opacity="0.25" />

        <!-- Step indicator -->
        <HBox fx:id="stepIndicator" alignment="CENTER" spacing="20">
            <VBox alignment="CENTER" spacing="4">
                <Label fx:id="step1Circle" text="1" styleClass="step-circle, step-active" />
                <Label text="Email" styleClass="step-label" />
            </VBox>
            <Separator prefWidth="30" />
            <VBox alignment="CENTER" spacing="4">
                <Label fx:id="step2Circle" text="2" styleClass="step-circle" />
                <Label text="2FA" styleClass="step-label" />
            </VBox>
            <Separator prefWidth="30" />
            <VBox alignment="CENTER" spacing="4">
                <Label fx:id="step3Circle" text="3" styleClass="step-circle" />
                <Label text="Face" styleClass="step-label" />
            </VBox>
            <Separator prefWidth="30" />
            <VBox alignment="CENTER" spacing="4">
                <Label fx:id="step4Circle" text="✓" styleClass="step-circle" />
                <Label text="Done" styleClass="step-label" />
            </VBox>
        </HBox>

        <!-- Email Verification Section -->
        <VBox fx:id="emailSection" spacing="16" alignment="CENTER">
            <ImageView fitWidth="80" fitHeight="80" preserveRatio="true">
                <image>
                    <Image url="@../images/site-images/logo.png" />
                </image>
            </ImageView>

            <Text fx:id="emailTitle" text="Verify your email address" styleClass="section-title" />
            <Text fx:id="emailDescription" text="We've sent a verification link to your email."
                  styleClass="subtitle" wrappingWidth="400" textAlignment="CENTER" />

            <Label fx:id="emailAddressLabel" text="" styleClass="email-highlight" />

            <VBox spacing="10" alignment="CENTER">
                <Button fx:id="resendEmailButton" text="Resend Verification Email"
                        onAction="#onResendEmail" styleClass="btn, btn-secondary" />
                <Button fx:id="checkEmailButton" text="I've Verified My Email"
                        onAction="#onCheckEmailVerification" styleClass="btn, btn-primary" />
            </VBox>

            <ProgressIndicator fx:id="emailProgress" visible="false" prefWidth="30" prefHeight="30" />
        </VBox>

        <!-- TOTP/Authenticator App Verification Section -->
        <VBox fx:id="totpSection" spacing="16" alignment="CENTER" visible="false" managed="false">
            <Text text="Set up Two-Factor Authentication" styleClass="section-title" />
            <Text fx:id="totpDescription" text="Scan this QR code with your authenticator app (Google Authenticator, Authy, etc.)"
                  styleClass="subtitle" wrappingWidth="400" textAlignment="CENTER" />

            <!-- QR Code Image -->
            <ImageView fx:id="qrCodeImage" fitWidth="200" fitHeight="200" preserveRatio="true" />

            <!-- Manual entry option -->
            <VBox spacing="4" alignment="CENTER">
                <Text text="Or enter this code manually:" styleClass="subtitle" style="-fx-font-size: 12px;" />
                <Label fx:id="secretKeyLabel" text="" styleClass="email-highlight" style="-fx-font-family: monospace; -fx-font-size: 14px;" />
            </VBox>

            <Separator opacity="0.25" />

            <Text text="Enter the 6-digit code from your app:" styleClass="subtitle" />

            <HBox alignment="CENTER" spacing="8">
                <TextField fx:id="pinField1" prefWidth="50" styleClass="pin-field" />
                <TextField fx:id="pinField2" prefWidth="50" styleClass="pin-field" />
                <TextField fx:id="pinField3" prefWidth="50" styleClass="pin-field" />
                <TextField fx:id="pinField4" prefWidth="50" styleClass="pin-field" />
                <TextField fx:id="pinField5" prefWidth="50" styleClass="pin-field" />
                <TextField fx:id="pinField6" prefWidth="50" styleClass="pin-field" />
            </HBox>

            <VBox spacing="10" alignment="CENTER">
                <Button fx:id="verifyTotpButton" text="Verify Code"
                        onAction="#onVerifyTotp" styleClass="btn, btn-primary" />
            </VBox>

            <ProgressIndicator fx:id="totpProgress" visible="false" prefWidth="30" prefHeight="30" />
        </VBox>

        <!-- Face Scan Verification Section -->
        <VBox fx:id="faceScanSection" spacing="16" alignment="CENTER" visible="false" managed="false">
            <Text text="Face Recognition Setup" styleClass="section-title" />
            <Text text="Position your face in front of the camera and click Capture"
                  styleClass="subtitle" wrappingWidth="400" textAlignment="CENTER" />

            <!-- Webcam Preview with bounding box overlay -->
            <StackPane>
                <ImageView fx:id="webcamPreview" fitWidth="320" fitHeight="240" preserveRatio="true" style="-fx-border-color: #ddd; -fx-border-radius: 8px;" />
                <Rectangle fx:id="faceBoundingBox" visible="false" fill="transparent" stroke="#4CAF50" strokeWidth="3" />
            </StackPane>

            <Label fx:id="faceScanStatusLabel" text="" styleClass="subtitle" />

            <VBox spacing="10" alignment="CENTER">
                <Button fx:id="captureFaceButton" text="Capture Face"
                        onAction="#onCaptureFace" styleClass="btn, btn-primary" />
            </VBox>

            <ProgressIndicator fx:id="faceScanProgress" visible="false" prefWidth="30" prefHeight="30" />
        </VBox>

        <!-- Success Section -->
        <VBox fx:id="successSection" spacing="16" alignment="CENTER" visible="false" managed="false">
            <Text text="🎉" style="-fx-font-size: 48px;" />
            <Text text="Verification Complete!" styleClass="section-title" />
            <Text text="Your account has been successfully verified." styleClass="subtitle" />

            <Button text="Continue to Profile" onAction="#onContinueToProfile"
                    styleClass="btn, btn-primary" />
        </VBox>

        <!-- Error/Status Label -->
        <Label fx:id="statusLabel" text="" styleClass="error-label" wrapText="true" textAlignment="CENTER" />

        <!-- Skip verification (for development/testing) -->
        <Hyperlink fx:id="skipLink" text="Skip verification (dev only)" onAction="#onSkipVerification"
                   visible="false" />
    </VBox>
</StackPane>


