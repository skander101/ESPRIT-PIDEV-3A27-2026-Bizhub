<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.bizhub.controller.elearning.formation.FormationDetailsController"
            stylesheets="@../css/theme.css">

    <!-- TOP BAR -->
    <top>
        <HBox fx:id="topbar" spacing="12" alignment="CENTER_LEFT" styleClass="topbar">
            <padding>
                <Insets top="14" right="16" bottom="14" left="16"/>
            </padding>

            <Text text="Formation details" styleClass="h1"/>
            <Pane HBox.hgrow="ALWAYS"/>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button
                        fx:id="addParticipationButton"
                        text="Participer"
                        onAction="#addParticipation"
                        styleClass="btn-primary btn-participer"
                        minWidth="80"
                        prefHeight="36"/>

                <Button
                        text="Back"
                        onAction="#goBack"
                        styleClass="btn"
                        minWidth="120"
                        prefHeight="36"/>
            </HBox>
        </HBox>
    </top>

    <!-- CENTER -->
    <center>
        <VBox spacing="14">
            <padding>
                <Insets top="14" right="16" bottom="16" left="16"/>
            </padding>

            <!-- FORMATION DETAILS -->
            <VBox styleClass="card" spacing="10">
                <Text fx:id="titleText" styleClass="h2"/>

                <GridPane hgap="12" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="20"/>
                        <ColumnConstraints percentWidth="80"/>
                    </columnConstraints>

                    <Label text="Trainer ID"/>
                    <Label fx:id="trainerLabel" GridPane.columnIndex="1"/>

                    <Label text="Start" GridPane.rowIndex="1"/>
                    <Label fx:id="startLabel" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="End" GridPane.rowIndex="2"/>
                    <Label fx:id="endLabel" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                    <Label text="Cost" GridPane.rowIndex="3"/>
                    <Label fx:id="costLabel" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                    <Label text="Lieu" GridPane.rowIndex="4"/>
                    <Label fx:id="lieuLabel" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                    <Label text="En ligne" GridPane.rowIndex="5"/>
                    <Label fx:id="enLigneLabel" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                </GridPane>

                <Text text="Description" styleClass="subtitle"/>
                <TextArea fx:id="descArea" editable="false" wrapText="true" prefRowCount="4"/>

                <Button
                        fx:id="leaveReviewButton"
                        text="Leave a review"
                        onAction="#leaveReview"
                        styleClass="btn-primary"/>
            </VBox>

            <!-- PARTICIPATIONS + REVIEWS side by side -->
            <HBox spacing="14" VBox.vgrow="ALWAYS">
                <VBox styleClass="card" spacing="10" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                    <Text text="Participations" styleClass="h2"/>
                    <TableView fx:id="participationsTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colPartUser" text="Participant" prefWidth="200"/>
                            <TableColumn fx:id="colPartDate" text="Date affectation" prefWidth="160"/>
                            <TableColumn fx:id="colPartRemarques" text="Remarques" prefWidth="250"/>
                        </columns>
                    </TableView>
                </VBox>

                <VBox styleClass="card" spacing="10" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                    <Text text="Reviews" styleClass="h2"/>
                    <TableView fx:id="reviewsTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colReviewer" text="Reviewer" prefWidth="240"/>
                            <TableColumn fx:id="colRating" text="Rating" prefWidth="90"/>
                            <TableColumn fx:id="colComment" text="Comment" prefWidth="300"/>
                            <TableColumn fx:id="colDate" text="Date" prefWidth="160"/>
                        </columns>
                    </TableView>
                </VBox>
            </HBox>

        </VBox>
    </center>
</BorderPane>

