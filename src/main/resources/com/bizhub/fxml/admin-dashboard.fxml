<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<BorderPane stylesheets="@../css/theme.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bizhub.user.controller.AdminDashboardController">

    <left>
        <fx:include source="admin-sidebar.fxml" />
    </left>

    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="topbar">
            <padding>
                <Insets bottom="14" left="16" right="16" top="14" />
            </padding>
            <Text styleClass="h1" text="Admin Dashboard" />
            <Pane HBox.hgrow="ALWAYS" />
            <Label fx:id="adminNameLabel" styleClass="subtitle" text="Admin" />
        </HBox>
    </top>

    <center>
        <VBox spacing="14">
            <padding>
                <Insets bottom="16" left="16" right="16" top="14" />
            </padding>

            <HBox spacing="12" VBox.vgrow="ALWAYS" />
        </VBox>
    </center>

</BorderPane>
