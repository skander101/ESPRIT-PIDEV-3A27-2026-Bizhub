<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.bizhub.participation.controller.ParticipationFormController"
      spacing="12" stylesheets="@../css/theme.css" styleClass="card">

    <padding>
        <Insets top="16" right="16" bottom="16" left="16" />
    </padding>

    <Text fx:id="titleText" text="Participation" styleClass="h1" />

    <GridPane hgap="12" vgap="10">
        <columnConstraints>
            <ColumnConstraints percentWidth="28" />
            <ColumnConstraints percentWidth="72" />
        </columnConstraints>

        <Label text="Formation" GridPane.rowIndex="0" GridPane.columnIndex="0" />
        <ComboBox fx:id="formationBox" GridPane.rowIndex="0" GridPane.columnIndex="1" />

        <Label text="Participant (user_id)" GridPane.rowIndex="1" GridPane.columnIndex="0" />
        <ComboBox fx:id="userBox" GridPane.rowIndex="1" GridPane.columnIndex="1" />

        <Label text="Date affectation" GridPane.rowIndex="2" GridPane.columnIndex="0" />
        <HBox spacing="8" GridPane.rowIndex="2" GridPane.columnIndex="1">
            <DatePicker fx:id="datePicker" />
            <TextField fx:id="timeField" promptText="HH:mm" prefColumnCount="5" />
        </HBox>

        <Label text="Remarques" GridPane.rowIndex="3" GridPane.columnIndex="0" />
        <TextArea fx:id="remarquesArea" prefRowCount="4" wrapText="true" GridPane.rowIndex="3" GridPane.columnIndex="1" />
    </GridPane>

    <Label fx:id="errorLabel" text="" styleClass="error-text" wrapText="true" />

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Annuler" onAction="#cancel" styleClass="btn" />
        <Button fx:id="saveButton" text="Enregistrer" onAction="#save" styleClass="btn-primary" />
    </HBox>

</VBox>
